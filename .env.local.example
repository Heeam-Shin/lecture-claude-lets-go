# Kakao REST API key — issued at https://developers.kakao.com (My Application → REST API key)
# Used by services/geocodingService.ts for keyword → 좌표 변환.
KAKAO_REST_API_KEY=

# Seoul Open Data API key — issued at https://data.seoul.go.kr (인증키 신청)
# Required for real subway arrival / 따릉이 station data. Currently routeCalculator falls back to
# distance-based estimates with mock line names and station names until this key is set.
SEOUL_API_KEY=
